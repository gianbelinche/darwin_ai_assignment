# NOTE: use the postgresql+asyncpg:// scheme — NOT postgres:// — for the async driver
DATABASE_URL=postgresql+asyncpg://expense_user:secret@postgres:5432/expenses

# Provider: "openai" or "groq" (groq has a free tier at console.groq.com)
LLM_PROVIDER=openai
LLM_API_KEY=sk-...

# OpenAI: gpt-4o-mini  |  Groq: llama-3.3-70b-versatile
LLM_MODEL=gpt-4o-mini

HOST=0.0.0.0
PORT=8000
